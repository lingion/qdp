# QDP example environment values
# Replace placeholders with real values before running authenticated flows.

# General runtime
QDP_WEB_HOST=127.0.0.1
QDP_WEB_PORT=17890

# Qobuz credentials / auth context
QDP_APP_ID=your-app-id
QDP_AUTH_TOKEN=your-user-auth-token

# Compatibility aliases also supported by the backend runtime
QOBUZ_APP_ID=your-app-id
QOBUZ_USER_AUTH_TOKEN=your-user-auth-token

# Optional overrides
QDP_USER_AGENT=Mozilla/5.0 (QDP Local Web Player)
QOBUZ_USER_AGENT=Mozilla/5.0
QDP_USE_TOKEN=true
